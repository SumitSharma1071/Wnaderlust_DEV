
<%if(success && success.length) { %>
<div class="alert alert-success alert-dismissible fade show col-6 offset-3 mt-2 flash-msg" id="flash" role="alert">
  <%= success %>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>

<%if(error && error.length) { %>
<div class="alert alert-danger alert-dismissible fade show col-6 offset-3 mt-2 flash-msg" id="flash" role="alert">
  <%= error %>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>

<script>
     const flash = document.getElementById("flash");

  setTimeout(() => {
    flash.classList.add("fade-out");

    // Completely remove after animation
    setTimeout(() => {
      flash.remove();
    }, 500);
  }, 3000);
</script>