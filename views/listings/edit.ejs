<% layout("/layout/boilerplate.ejs") %>

<body>
    <div class="row edit">
        <div class="col-8 offset-2">
            <h1>Edit Listing</h1>
        <form action="/listing/<%= list._id %>?_method=PUT" method="post" novalidate class="needs-validation" enctype="multipart/form-data">

        <div class="mb-2">
            <label for="listing[title]" class="from-label">Title :</label>
            <input type="text" name="listing[title]" value="<%= list.title %>" class="form-control" required>
            <div class="invalid-feedback">Enter a Title</div>
        </div>

        <div class="mb-2">
            <label for="listing[description]" class="from-label">Description : </label>
            <input type="text" name="listing[description]" value="<%= list.description %>" class="form-control" required>
            <div class="invalid-feedback">Enter a short Description</div>
        </div>

       <div class="mb-2">
            <label for="listing[image][url]" class="from-label">Image : </label>
            <input type="file" name="listing[image][url]" value="<%= list.image.url %>" class="form-control">
            <div class="invalid-feedback">Enter a image url</div>
        </div>

        <div class="row">
             <div class="mb-2 col-md-4">
            <label for="listing[price]" class="from-label">Price :</label>
            <input type="text" name="listing[price]" value="<%= list.price %>" class="form-control" required>
             <div class="invalid-feedback">Enter a appropriate Price</div>
        </div>

        <div class="mb-2 col-md-8">
            <label for="listing[country]" class="from-label">Country</label>
            <input type="text" name="listing[country]" value="<%= list.country %>" class="form-control" required>
            <div class="invalid-feedback">Country Name should be Valid</div>
        </div>

        </div>

         <div class="mb-2">
            <label for="listing[location]" class="from-label">location :</label>
            <input type="text" name="listing[location]" value="<%= list.location %>" class="form-control" required>
            <div class="invalid-feedback">Location should be valid</div>
        </div><br>

        <button type="submit" class="btn btn-danger">Update Listing</button>
    </form>
    </div>
   </div>
</body>
